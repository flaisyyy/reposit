<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:padding="10sp" android:layout_width="match_parent" android:layout_height="match_parent">
    <EditText android:id="@+id/login_dialog_username" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/login_dialog_username" android:ems="10">
        <requestFocus/>
    </EditText>
    <EditText android:id="@+id/login_dialog_password" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/login_dialog_password" android:ems="10" android:inputType="textPassword"/>
</LinearLayout>
