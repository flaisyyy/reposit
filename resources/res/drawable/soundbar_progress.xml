<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <stroke android:width="1px" android:color="#ff888888"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip android:gravity="bottom|center_vertical|center_horizontal|center" android:clipOrientation="vertical">
            <shape>
                <stroke android:width="4dp" android:color="#00000000"/>
                <solid android:color="#cc6296ff"/>
            </shape>
        </clip>
    </item>
</layer-list>
